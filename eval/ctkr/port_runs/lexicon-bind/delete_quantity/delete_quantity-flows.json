{
  "version": 1,
  "flows": [
    {
      "key": "w2x-delete-quantity-removes-only-the-target",
      "title": "One of two quantities on a harvest deleted: exactly the deleted measurement is gone, the sibling stands",
      "feature": "harvest",
      "glossary_terms": ["land", "harvest", "weight", "count", "record_log", "delete_quantity", "quantity_recorded", "yield_total", "log_count"],
      "given": [{"entity": "land", "alias": "A", "name": "w2x-DelQty Bed One"}],
      "when": [
        {"action": "record_log", "alias": "L", "kind": "harvest", "status": "done", "name": "w2x-Harvest losing one measurement", "against": ["A"], "quantities": [
          {"measure": "weight", "value": 3, "unit": "kilogram", "label": "yield", "alias": "Q1"},
          {"measure": "count", "value": 12, "unit": "head", "label": "yield", "alias": "Q2"}
        ]},
        {"action": "delete_quantity", "ref": "Q1"}
      ],
      "probes": [
        {"assert": "quantity_recorded", "subject": "L", "measure": "weight", "unit": "kilogram"},
        {"assert": "quantity_recorded", "subject": "L", "measure": "count", "unit": "head"},
        {"assert": "yield_total", "subject": "A", "measure": "weight", "unit": "kilogram"},
        {"assert": "yield_total", "subject": "A", "measure": "count", "unit": "head"},
        {"assert": "log_count", "subject": "A", "kind": "harvest"}
      ]
    },
    {
      "key": "w2x-delete-quantity-kept-contrast",
      "title": "The same two measurements left in place: both stand — the discriminating contrast to the deletion",
      "feature": "harvest",
      "glossary_terms": ["land", "harvest", "weight", "count", "record_log", "quantity_recorded", "yield_total", "log_count"],
      "given": [{"entity": "land", "alias": "A", "name": "w2x-DelQty Bed Two"}],
      "when": [
        {"action": "record_log", "alias": "L", "kind": "harvest", "status": "done", "name": "w2x-Harvest keeping both measurements", "against": ["A"], "quantities": [
          {"measure": "weight", "value": 3, "unit": "kilogram", "label": "yield", "alias": "Q1"},
          {"measure": "count", "value": 12, "unit": "head", "label": "yield", "alias": "Q2"}
        ]}
      ],
      "probes": [
        {"assert": "quantity_recorded", "subject": "L", "measure": "weight", "unit": "kilogram"},
        {"assert": "quantity_recorded", "subject": "L", "measure": "count", "unit": "head"},
        {"assert": "yield_total", "subject": "A", "measure": "weight", "unit": "kilogram"},
        {"assert": "yield_total", "subject": "A", "measure": "count", "unit": "head"},
        {"assert": "log_count", "subject": "A", "kind": "harvest"}
      ]
    },
    {
      "key": "w2x-delete-log-orphans-no-quantity",
      "title": "Deleting a log then its quantity: the delete_log registry claim says the cascade already removed it, so the second delete must be REFUSED — a quantity surviving orphaned would accept the write and surface as a contradiction",
      "feature": "harvest",
      "glossary_terms": ["land", "harvest", "weight", "record_log", "delete_log", "delete_quantity"],
      "given": [{"entity": "land", "alias": "A", "name": "w2x-DelQty Bed Three"}],
      "when": [
        {"action": "record_log", "alias": "L", "kind": "harvest", "status": "done", "name": "w2x-Harvest deleted whole", "against": ["A"], "quantities": [
          {"measure": "weight", "value": 5, "unit": "kilogram", "label": "yield", "alias": "Q"}
        ]},
        {"action": "delete_log", "ref": "L"},
        {"action": "delete_quantity", "ref": "Q"}
      ],
      "probes": [],
      "expect_refusal": true
    }
  ]
}
