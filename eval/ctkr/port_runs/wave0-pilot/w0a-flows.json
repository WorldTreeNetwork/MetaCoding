          "measure": "weight",
          "unit": "kilograms"
        },
        {
          "assert": "adjustment_count",
          "subject": "bin"
        }
      ]
    },
    {
      "key": "w0a-confirming-a-pending-adjustment-admits-it",
      "title": "Confirming a pending adjustment admits it into the running stock",
      "feature": "core.inventory",
      "glossary_terms": [
        "equipment",
        "record_inventory_adjustment",
        "set_log_status",
        "increment",
        "pending",
        "done",
        "weight",
        "stock_on_hand"
      ],
      "given": [
        {
          "entity": "equipment",
          "alias": "bin",
          "name": "feed bin six"
        }
      ],
      "when": [
        {
          "action": "record_inventory_adjustment",
          "alias": "adj_pending",
          "kind": "increment",
          "against": [
            "bin"
          ],
          "at": "-10000",
          "status": "pending",
          "name": "delivery awaiting confirmation",
          "quantities": [
            {
              "measure": "weight",
              "value": 7,
              "unit": "kilograms"
            }
          ]
        },
        {
          "action": "set_log_status",
          "ref": "adj_pending",
          "status": "done"
        }
