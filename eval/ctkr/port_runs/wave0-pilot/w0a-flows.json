        {
          "assert": "stock_pair_count",
          "subject": "bin"
        }
      ]
    },
    {
      "key": "w0a-restating-when-an-adjustment-took-effect",
      "title": "Restating when an adjustment took effect changes whether it counts",
      "feature": "core.inventory",
      "glossary_terms": [
        "equipment",
        "record_inventory_adjustment",
        "set_effective_time",
        "increment",
        "done",
        "weight",
        "stock_on_hand"
      ],
      "given": [
        {
          "entity": "equipment",
          "alias": "bin",
          "name": "feed bin seven"
        }
      ],
      "when": [
        {
          "action": "record_inventory_adjustment",
          "alias": "adj_ahead",
          "kind": "increment",
          "against": [
            "bin"
          ],
          "at": "+86400",
          "status": "done",
          "name": "delivery mis-dated ahead",
          "quantities": [
            {
              "measure": "weight",
              "value": 5,
              "unit": "kilograms"
            }
          ]
        },
        {
          "action": "set_effective_time",
          "ref": "adj_ahead",
          "at": "-10000"
        }
      ],
      "probes": [
        {
          "assert": "stock_on_hand",
          "subject": "bin",
          "measure": "weight",
          "unit": "kilograms"
        },
        {
          "assert": "adjustment_count",
          "subject": "bin"
        }
      ]
    },
