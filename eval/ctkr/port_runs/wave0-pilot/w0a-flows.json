          "at": "-20000",
          "status": "done",
          "name": "second count",
          "quantities": [
            {
              "measure": "weight",
              "value": 2,
              "unit": "kilograms"
            }
          ]
        },
        {
          "action": "record_inventory_adjustment",
          "alias": "adj_late",
          "kind": "increment",
          "against": [
            "bin"
          ],
          "at": "-10000",
          "status": "done",
          "name": "stock topped up",
          "quantities": [
            {
              "measure": "weight",
