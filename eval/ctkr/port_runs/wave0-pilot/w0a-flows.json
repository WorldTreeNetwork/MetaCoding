{
  "version": 1,
  "flows": [
    {
      "key": "w0a-reset-assigns-then-deltas-accumulate",
      "title": "A reset assigns the running stock; only deltas after it accumulate",
      "feature": "core.inventory",
      "glossary_terms": [
        "equipment",
        "record_inventory_adjustment",
        "increment",
        "decrement",
        "reset",
        "weight",
        "stock_on_hand",
        "adjustment_count"
      ],
      "given": [
        {
          "entity": "equipment",
          "alias": "bin",
          "name": "feed bin one"
        }
      ],
      "when": [
        {
          "action": "record_inventory_adjustment",
          "alias": "adj_up",
          "kind": "increment",
          "against": [
            "bin"
          ],
          "at": "-30000",
          "status": "done",
          "name": "stock added",
          "quantities": [
            {
              "measure": "weight",
              "value": 10,
              "unit": "kilograms"
            }
          ]
        },
        {
          "action": "record_inventory_adjustment",
          "alias": "adj_reset",
          "kind": "reset",
          "against": [
            "bin"
          ],
          "at": "-20000",
          "status": "done",
          "name": "stock counted",
          "quantities": [
            {
              "measure": "weight",
              "value": 4,
              "unit": "kilograms"
            }
          ]
        },
        {
          "action": "record_inventory_adjustment",
          "alias": "adj_down",
          "kind": "decrement",
          "against": [
            "bin"
          ],
          "at": "-10000",
          "status": "done",
          "name": "stock drawn",
          "quantities": [
            {
              "measure": "weight",
              "value": 1,
              "unit": "kilograms"
            }
          ]
        }
      ],
      "probes": [
        {
          "assert": "stock_on_hand",
          "subject": "bin",
          "measure": "weight",
          "unit": "kilograms"
        },
        {
          "assert": "stock_pair_count",
          "subject": "bin"
        },
        {
          "assert": "adjustment_count",
          "subject": "bin"
        }
      ]
    },
    {
      "key": "w0a-history-before-a-reset-is-discarded",
      "title": "Adjustments earlier than the reset do not survive it",
      "feature": "core.inventory",
      "glossary_terms": [
        "equipment",
        "record_inventory_adjustment",
        "increment",
        "reset",
        "weight",
        "stock_on_hand"
      ],
      "given": [
        {
          "entity": "equipment",
          "alias": "bin",
          "name": "feed bin two"
        }
      ],
      "when": [
        {
          "action": "record_inventory_adjustment",
          "alias": "adj_up",
          "kind": "increment",
          "against": [
            "bin"
          ],
          "at": "-30000",
          "status": "done",
          "name": "stock added",
          "quantities": [
            {
              "measure": "weight",
              "value": 10,
              "unit": "kilograms"
            }
          ]
        },
        {
          "action": "record_inventory_adjustment",
          "alias": "adj_reset",
          "kind": "reset",
          "against": [
            "bin"
          ],
          "at": "-20000",
          "status": "done",
          "name": "stock counted empty",
          "quantities": [
            {
              "measure": "weight",
              "value": 0,
              "unit": "kilograms"
            }
          ]
        }
      ],
      "probes": [
        {
          "assert": "stock_on_hand",
          "subject": "bin",
          "measure": "weight",
          "unit": "kilograms"
        },
        {
          "assert": "stock_pair_count",
          "subject": "bin"
        }
      ]
    },
    {
      "key": "w0a-latest-reset-is-the-only-base",
      "title": "With two resets, only the later one seeds the running stock",
