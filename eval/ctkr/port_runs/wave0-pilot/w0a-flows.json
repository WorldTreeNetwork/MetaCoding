      "glossary_terms": [
        "equipment",
        "record_inventory_adjustment",
        "increment",
        "pending",
        "done",
        "weight",
        "stock_on_hand",
        "adjustment_count"
      ],
      "given": [
        {
          "entity": "equipment",
          "alias": "bin",
          "name": "feed bin four"
        }
      ],
      "when": [
        {
          "action": "record_inventory_adjustment",
          "alias": "adj_done",
          "kind": "increment",
          "against": [
            "bin"
          ],
          "at": "-20000",
          "status": "done",
