{
  "version": 1,
  "flows": [
    {
      "key": "w0b-birth-mother-adopted-by-parentless-child",
      "title": "A birth record's mother becomes the child's parent when the child had no parent at all",
      "feature": "birth",
      "glossary_terms": [
        "animal",
        "record_birth",
        "has_parent",
        "parent_count",
        "birth_date",
        "birth_record_count",
        "birth"
      ],
      "given": [
        {
          "entity": "animal",
          "alias": "CHILD",
          "name": "Calf Aster",
          "descriptor": "Cattle",
          "sex": "F"
        },
        {
          "entity": "animal",
          "alias": "MOTHER",
          "name": "Cow Marigold",
          "descriptor": "Cattle",
          "sex": "F"
        }
      ],
      "when": [
        {
          "action": "record_birth",
          "alias": "BIRTH",
          "ref": "CHILD",
          "parents": [
            "MOTHER"
          ],
          "name": "birth of Aster",
          "status": "done",
          "at": "2026-07-13T12:00:00+00:00"
        }
      ],
      "probes": [
        {
          "assert": "parent_count",
          "subject": "CHILD"
        },
        {
          "assert": "has_parent",
          "subject": "CHILD",
          "other": "MOTHER"
        },
        {
          "assert": "birth_date",
          "subject": "CHILD"
        },
        {
          "assert": "birth_record_count",
          "subject": "CHILD"
        }
      ]
    },
    {
      "key": "w0b-birth-mother-vetoed-by-existing-parent",
      "title": "An existing parent is a complete veto: a later birth record's mother is not added alongside it",
      "feature": "birth",
      "glossary_terms": [
        "animal",
        "set_parents",
        "record_birth",
        "has_parent",
        "parent_count",
        "birth_record_count",
        "birth"
      ],
      "given": [
        {
          "entity": "animal",
          "alias": "CHILD",
          "name": "Calf Birch",
          "descriptor": "Cattle",
          "sex": "M"
        },
        {
          "entity": "animal",
          "alias": "MOTHER",
          "name": "Cow Nettle",
          "descriptor": "Cattle",
          "sex": "F"
        },
        {
          "entity": "animal",
          "alias": "OTHERPARENT",
          "name": "Cow Sorrel",
          "descriptor": "Cattle",
          "sex": "F"
        }
      ],
      "when": [
        {
          "action": "set_parents",
          "ref": "CHILD",
          "parents": [
            "OTHERPARENT"
          ]
        },
        {
          "action": "record_birth",
          "alias": "BIRTH",
          "ref": "CHILD",
          "parents": [
            "MOTHER"
          ],
          "name": "birth of Birch",
          "status": "done",
          "at": "2026-07-15T12:00:00+00:00"
        }
      ],
      "probes": [
        {
          "assert": "parent_count",
          "subject": "CHILD"
        },
        {
          "assert": "has_parent",
          "subject": "CHILD",
          "other": "MOTHER"
        },
        {
          "assert": "has_parent",
          "subject": "CHILD",
          "other": "OTHERPARENT"
        },
        {
          "assert": "birth_record_count",
          "subject": "CHILD"
        }
      ]
    },
    {
      "key": "w0b-birth-correction-restates-mother",
      "title": "Correcting a recorded birth to name a different mother \u2014 is the earlier parent replaced or kept",
      "feature": "birth",
      "glossary_terms": [
        "animal",
        "record_birth",
        "correct_birth",
        "has_parent",
        "parent_count",
        "birth_record_count",
        "birth"
      ],
      "given": [
        {
          "entity": "animal",
          "alias": "CHILD",
          "name": "Lamb Cedar",
          "descriptor": "Sheep",
          "sex": "F"
        },
        {
          "entity": "animal",
          "alias": "FIRSTMOTHER",
          "name": "Ewe Heather",
          "descriptor": "Sheep",
          "sex": "F"
        },
        {
          "entity": "animal",
          "alias": "SECONDMOTHER",
          "name": "Ewe Juniper",
          "descriptor": "Sheep",
          "sex": "F"
        }
      ],
      "when": [
        {
          "action": "record_birth",
          "alias": "BIRTH",
          "ref": "CHILD",
          "parents": [
            "FIRSTMOTHER"
          ],
          "name": "birth of Cedar",
          "status": "done",
          "at": "2026-07-13T12:00:00+00:00"
        },
        {
          "action": "correct_birth",
          "ref": "BIRTH",
          "parents": [
            "SECONDMOTHER"
          ]
        }
      ],
      "probes": [
        {
          "assert": "parent_count",
          "subject": "CHILD"
        },
        {
          "assert": "has_parent",
          "subject": "CHILD",
          "other": "FIRSTMOTHER"
        },
        {
          "assert": "has_parent",
          "subject": "CHILD",
          "other": "SECONDMOTHER"
        },
        {
          "assert": "birth_record_count",
          "subject": "CHILD"
        }
      ]
    },
