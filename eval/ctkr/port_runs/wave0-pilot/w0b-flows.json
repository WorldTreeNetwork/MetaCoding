    {
      "key": "w0b-two-birth-records-one-animal",
      "title": "Two independent birth records claiming the same animal as issue \u2014 which claim the animal is delivered with",
      "feature": "birth",
      "glossary_terms": [
        "animal",
        "record_birth",
        "has_parent",
        "parent_count",
        "birth_date",
        "birth_record_count",
        "birth"
      ],
      "given": [
        {
          "entity": "animal",
          "alias": "CHILD",
          "name": "Kid Fennel",
          "descriptor": "Goat",
          "sex": "M"
        },
        {
          "entity": "animal",
          "alias": "FIRSTMOTHER",
          "name": "Doe Willow",
          "descriptor": "Goat",
          "sex": "F"
        },
        {
          "entity": "animal",
          "alias": "SECONDMOTHER",
          "name": "Doe Rowan",
          "descriptor": "Goat",
          "sex": "F"
        }
      ],
      "when": [
        {
          "action": "record_birth",
          "alias": "FIRSTBIRTH",
          "ref": "CHILD",
          "parents": [
            "FIRSTMOTHER"
          ],
          "name": "first birth claim for Fennel",
          "status": "done",
          "at": "2026-07-13T12:00:00+00:00"
        },
        {
          "action": "record_birth",
          "alias": "SECONDBIRTH",
          "ref": "CHILD",
          "parents": [
            "SECONDMOTHER"
          ],
          "name": "second birth claim for Fennel",
          "status": "done",
          "at": "2026-07-14T12:00:00+00:00"
        }
      ],
      "probes": [
        {
          "assert": "birth_record_count",
          "subject": "CHILD"
        },
        {
          "assert": "parent_count",
          "subject": "CHILD"
        },
        {
          "assert": "has_parent",
          "subject": "CHILD",
          "other": "FIRSTMOTHER"
        },
        {
          "assert": "has_parent",
          "subject": "CHILD",
          "other": "SECONDMOTHER"
        },
        {
          "assert": "birth_date",
          "subject": "CHILD"
        }
      ]
    },
    {
