      ],
      "given": [
        {
          "entity": "animal",
          "alias": "CHILD",
          "name": "Piglet Gorse",
          "descriptor": "Pig",
          "sex": "F"
        },
        {
          "entity": "animal",
          "alias": "MOTHER",
          "name": "Sow Larkspur",
